# Kingly backend – copy to .env and fill in (do not commit .env)

# Gemini / Google AI (required for ADK agents)
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Or: GEMINI_API_KEY=

# Optional: override default model (e.g. gemini-2.5-flash)
# MODEL=gemini-2.5-flash

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT Secret (Legacy; Project Settings > API). Optional if using new JWT signing keys (JWKS).
# Backend verifies with JWKS first, then falls back to this.
SUPABASE_JWT_SECRET=

# Yoco – optional, for future payments (sk_test_... or sk_live_...)
# YOCO_SECRET_KEY=
